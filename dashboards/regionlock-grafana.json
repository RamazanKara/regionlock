{
  "title": "Regionlock: Data Residency Compliance",
  "uid": "regionlock",
  "schemaVersion": 39,
  "version": 1,
  "editable": true,
  "time": { "from": "now-30d", "to": "now" },
  "refresh": "5m",
  "tags": ["regionlock", "compliance", "data-residency", "sovereignty"],
  "templating": {
    "list": [
      {
        "name": "datasource",
        "type": "datasource",
        "query": "prometheus",
        "label": "Prometheus",
        "hide": 0,
        "current": {}
      }
    ]
  },
  "panels": [
    {
      "id": 1,
      "type": "stat",
      "title": "Compliance score",
      "gridPos": { "h": 6, "w": 6, "x": 0, "y": 0 },
      "datasource": { "type": "prometheus", "uid": "${datasource}" },
      "fieldConfig": {
        "defaults": {
          "unit": "percentunit",
          "min": 0,
          "max": 1,
          "thresholds": {
            "mode": "absolute",
            "steps": [
              { "color": "red", "value": null },
              { "color": "yellow", "value": 0.8 },
              { "color": "green", "value": 1 }
            ]
          }
        },
        "overrides": []
      },
      "targets": [{ "expr": "min(regionlock_compliance_ratio)", "refId": "A" }]
    },
    {
      "id": 2,
      "type": "stat",
      "title": "Failing checks",
      "gridPos": { "h": 6, "w": 6, "x": 6, "y": 0 },
      "datasource": { "type": "prometheus", "uid": "${datasource}" },
      "fieldConfig": {
        "defaults": {
          "unit": "short",
          "thresholds": {
            "mode": "absolute",
            "steps": [
              { "color": "green", "value": null },
              { "color": "red", "value": 1 }
            ]
          }
        },
        "overrides": []
      },
      "targets": [{ "expr": "sum(regionlock_checks{status=\"fail\"})", "refId": "A" }]
    },
    {
      "id": 3,
      "type": "timeseries",
      "title": "Violations by control",
      "gridPos": { "h": 8, "w": 12, "x": 12, "y": 0 },
      "datasource": { "type": "prometheus", "uid": "${datasource}" },
      "fieldConfig": { "defaults": { "unit": "short" }, "overrides": [] },
      "targets": [
        { "expr": "sum by (rule) (regionlock_violations)", "legendFormat": "{{rule}}", "refId": "A" }
      ]
    },
    {
      "id": 4,
      "type": "table",
      "title": "Current violations by control and severity",
      "gridPos": { "h": 8, "w": 12, "x": 0, "y": 6 },
      "datasource": { "type": "prometheus", "uid": "${datasource}" },
      "targets": [
        { "expr": "regionlock_violations > 0", "format": "table", "instant": true, "refId": "A" }
      ]
    },
    {
      "id": 5,
      "type": "timeseries",
      "title": "Compliance score over time",
      "gridPos": { "h": 8, "w": 12, "x": 12, "y": 8 },
      "datasource": { "type": "prometheus", "uid": "${datasource}" },
      "fieldConfig": { "defaults": { "unit": "percentunit", "min": 0, "max": 1 }, "overrides": [] },
      "targets": [
        { "expr": "min(regionlock_compliance_ratio)", "legendFormat": "score", "refId": "A" }
      ]
    }
  ]
}
