# Source: regionlock/templates/gatekeeper-eu-region.yaml
apiVersion: templates.gatekeeper.sh/v1
kind: ConstraintTemplate
metadata:
  name: regionlockeuregion
  labels:
    app.kubernetes.io/name: regionlock
    app.kubernetes.io/managed-by: regionlock
    app.kubernetes.io/instance: regionlock
    app.kubernetes.io/version: "1.0.0"
    regionlock.io/ruleset: «.RulesetID»
  annotations:
    regionlock.io/rule-id: eu-region-placement
    regionlock.io/articles: "GDPR Art. 44; GDPR Art. 45; EU Data Act Art. 32"
spec:
  crd:
    spec:
      names:
        kind: RegionlockEuRegion
      validation:
        openAPIV3Schema:
          type: object
          properties:
            requireRegion:
              type: boolean
            allowedRegions:
              type: array
              items:
                type: string
  targets:
    - target: admission.k8s.gatekeeper.sh
      rego: |
        package regionlockeuregion

        # The pod spec, resolved per workload kind so controllers (Deployment,
        # StatefulSet, DaemonSet, ReplicaSet, Job, CronJob) are covered too, not
        # only bare Pods. Mutually exclusive guards, so no conflicting values.
        pod_spec := input.review.object.spec {
          input.review.kind.kind == "Pod"
        }
        pod_spec := input.review.object.spec.template.spec {
          controller_kinds[input.review.kind.kind]
        }
        pod_spec := input.review.object.spec.jobTemplate.spec.template.spec {
          input.review.kind.kind == "CronJob"
        }

        controller_kinds := {"Deployment", "StatefulSet", "DaemonSet", "ReplicaSet", "Job"}

        # The region label keys Regionlock recognizes: the well-known key and the
        # deprecated beta key (matching the CLI).
        region_keys := {"topology.kubernetes.io/region", "failure-domain.beta.kubernetes.io/region"}

        # nodeSelector region pin outside the EU (either region key).
        violation[{"msg": msg}] {
          region := nodeselector_regions[_]
          not region_allowed(region)
          msg := sprintf("BLOCKED: non-EU region \"%v\" (nodeSelector) violates EU data-residency policy [GDPR Art. 44]", [region])
        }

        # required nodeAffinity In-term pinning region outside the EU.
        violation[{"msg": msg}] {
          region := affinity_region_values[_]
          not region_allowed(region)
          msg := sprintf("BLOCKED: non-EU region \"%v\" (nodeAffinity) violates EU data-residency policy [GDPR Art. 44]", [region])
        }

        # Not guaranteed to stay in-region: no nodeSelector region pin AND the
        # affinity does not constrain every term to a region (an OR escape hatch,
        # or no affinity at all).
        violation[{"msg": msg}] {
          input.parameters.requireRegion
          not has_nodeselector_region
          not all_terms_region_constrained
          msg := "BLOCKED: workload is not guaranteed to stay in an EU region. Pin topology.kubernetes.io/region on nodeSelector or EVERY nodeAffinity term [GDPR Art. 44]"
        }

        nodeselector_regions[v] {
          region_keys[k]
          v := pod_spec.nodeSelector[k]
        }

        has_nodeselector_region {
          nodeselector_regions[_]
        }

        affinity_terms := pod_spec.affinity.nodeAffinity.requiredDuringSchedulingIgnoredDuringExecution.nodeSelectorTerms

        all_terms_region_constrained {
          count(affinity_terms) > 0
          count([t | t := affinity_terms[_]; term_has_region(t)]) == count(affinity_terms)
        }

        # A term constrains the region only if it has an In-expression on a region
        # key with a non-empty values list (an empty In pins nothing).
        term_has_region(t) {
          expr := t.matchExpressions[_]
          region_keys[expr.key]
          expr.operator == "In"
          count(expr.values) > 0
        }

        affinity_region_values[v] {
          term := affinity_terms[_]
          expr := term.matchExpressions[_]
          region_keys[expr.key]
          expr.operator == "In"
          v := expr.values[_]
        }

        region_allowed(region) {
          input.parameters.allowedRegions[_] == region
        }
