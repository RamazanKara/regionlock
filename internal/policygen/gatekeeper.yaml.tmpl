# Source: regionlock/templates/gatekeeper-egress.yaml
apiVersion: templates.gatekeeper.sh/v1
kind: ConstraintTemplate
metadata:
  name: regionlocknoegress
  labels:
    app.kubernetes.io/name: regionlock
    app.kubernetes.io/managed-by: regionlock
    app.kubernetes.io/instance: regionlock
    app.kubernetes.io/version: "1.0.0"
    regionlock.io/ruleset: «.RulesetID»
  annotations:
    regionlock.io/rule-id: no-non-eu-egress
    regionlock.io/articles: "GDPR Art. 44; GDPR Art. 46"
spec:
  crd:
    spec:
      names:
        kind: RegionlockNoEgress
      validation:
        openAPIV3Schema:
          type: object
          properties:
            allowExternalName:
              type: boolean
            allowExternalIPs:
              type: boolean
  targets:
    - target: admission.k8s.gatekeeper.sh
      rego: |
        package regionlocknoegress

        violation[{"msg": msg}] {
          input.review.kind.kind == "Service"
          input.review.object.spec.type == "ExternalName"
          not input.parameters.allowExternalName
          msg := sprintf("BLOCKED: Service type=ExternalName proxies to external endpoint %v (potential extra-EU transfer) [GDPR Art. 44]", [input.review.object.spec.externalName])
        }

        # externalIPs is independent of ExternalName, gated by its own parameter.
        violation[{"msg": msg}] {
          input.review.kind.kind == "Service"
          count(object.get(input.review.object.spec, "externalIPs", [])) > 0
          not input.parameters.allowExternalIPs
          msg := sprintf("BLOCKED: Service exposes externalIPs %v (destination not verifiable as EU) [GDPR Art. 44]", [input.review.object.spec.externalIPs])
        }

        # an egress rule with no peer selector (empty/absent `to`) permits egress anywhere.
        violation[{"msg": msg}] {
          input.review.kind.kind == "NetworkPolicy"
          rule := input.review.object.spec.egress[_]
          count(object.get(rule, "to", [])) == 0
          msg := "BLOCKED: NetworkPolicy egress rule with no peer selector permits egress to any destination [GDPR Art. 46]"
        }

        # Constant message so multiple open CIDRs in one policy dedupe to a single
        # violation (matching the Kyverno per-policy behavior).
        violation[{"msg": msg}] {
          input.review.kind.kind == "NetworkPolicy"
          unrestricted(input.review.object.spec.egress[_].to[_].ipBlock.cidr)
          msg := "BLOCKED: NetworkPolicy permits a default-route egress (/0 or /1), which can reach non-EU destinations [GDPR Art. 46]"
        }

        # A default route (/0) or a default-route half (/1, e.g. the 0.0.0.0/1 +
        # 128.0.0.0/1 split that together cover the whole space) is unrestricted.
        unrestricted(cidr) { endswith(cidr, "/0") }
        unrestricted(cidr) { endswith(cidr, "/1") }
