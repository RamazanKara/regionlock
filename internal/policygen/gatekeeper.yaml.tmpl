apiVersion: templates.gatekeeper.sh/v1
kind: ConstraintTemplate
metadata:
  name: regionlockcmk
  labels:
    app.kubernetes.io/name: regionlock
    app.kubernetes.io/managed-by: regionlock
    app.kubernetes.io/instance: regionlock
    app.kubernetes.io/version: "1.0.0"
    regionlock.io/ruleset: «.RulesetID»
  annotations:
    regionlock.io/rule-id: customer-managed-key
    regionlock.io/articles: "GDPR Art. 32"
spec:
  crd:
    spec:
      names:
        kind: RegionlockCmk
      validation:
        openAPIV3Schema:
          type: object
          properties:
            cmkAnnotation:
              type: string
            approvedStorageClasses:
              type: array
              items:
                type: string
  targets:
    - target: admission.k8s.gatekeeper.sh
      rego: |
        package regionlockcmk

        violation[{"msg": msg}] {
          ann := object.get(input.review.object.metadata, "annotations", {})
          object.get(ann, input.parameters.cmkAnnotation, "") == ""
          not approved_sc
          msg := sprintf("BLOCKED: PersistentVolumeClaim must reference a customer-managed key (annotation %v or an approved StorageClass) [GDPR Art. 32]", [input.parameters.cmkAnnotation])
        }

        approved_sc {
          sc := object.get(input.review.object.spec, "storageClassName", "")
          sc != ""
          input.parameters.approvedStorageClasses[_] == sc
        }
