# Source: regionlock/templates/policy-egress.yaml
apiVersion: kyverno.io/v1
kind: ClusterPolicy
metadata:
  name: regionlock-no-non-eu-egress
  labels:
    app.kubernetes.io/name: regionlock
    app.kubernetes.io/managed-by: regionlock
    app.kubernetes.io/instance: regionlock
    app.kubernetes.io/version: "1.0.0"
    regionlock.io/ruleset: «.RulesetID»
  annotations:
    regionlock.io/rule-id: no-non-eu-egress
    policies.kyverno.io/title: No Non-EU Egress
    policies.kyverno.io/severity: high
    policies.kyverno.io/category: EU Data Residency
    policies.kyverno.io/subject: Service, NetworkPolicy
    regionlock.io/articles: "GDPR Art. 44; GDPR Art. 46"
    policies.kyverno.io/description: >-
      Services must not proxy to external endpoints (ExternalName) and
      NetworkPolicies must not permit unrestricted (0.0.0.0/0, ::/0) egress that
      could carry personal data to destinations outside the EEA.
spec:
  validationFailureAction: Enforce
  background: true
  rules:
    - name: no-externalname-service
      match:
        any:
          - resources:
              kinds:
                - Service
      
      exclude:
        any:
          - resources:
              namespaces:
                - kube-system
                - kube-node-lease
                - kube-public
                - kyverno
                - regionlock
      validate:
        message: >-
          BLOCKED: Service type=ExternalName proxies outside the cluster and may transfer data outside the EEA [GDPR Art. 44]
        deny:
          conditions:
            all:
              - key: "{{ request.object.spec.type || '' }}"
                operator: Equals
                value: ExternalName
    - name: no-external-ips-service
      match:
        any:
          - resources:
              kinds:
                - Service
      
      exclude:
        any:
          - resources:
              namespaces:
                - kube-system
                - kube-node-lease
                - kube-public
                - kyverno
                - regionlock
      validate:
        message: >-
          BLOCKED: Service exposes externalIPs, whose destination is not verifiable as EU [GDPR Art. 44]
        deny:
          conditions:
            all:
              - key: "{{ length(request.object.spec.externalIPs || '') }}"
                operator: GreaterThan
                value: 0
    - name: no-unrestricted-egress-cidr
      match:
        any:
          - resources:
              kinds:
                - NetworkPolicy
      
      exclude:
        any:
          - resources:
              namespaces:
                - kube-system
                - kube-node-lease
                - kube-public
                - kyverno
                - regionlock
      validate:
        message: >-
          BLOCKED: NetworkPolicy permits a default-route egress (/0), which can reach non-EU destinations [GDPR Art. 46]
        deny:
          conditions:
            all:
              - key: "{{ length(request.object.spec.egress[].to[].ipBlock.cidr | [?ends_with(@, '/0') || ends_with(@, '/1')] || '') }}"
                operator: GreaterThan
                value: 0
    - name: no-open-egress-rule
      match:
        any:
          - resources:
              kinds:
                - NetworkPolicy
      
      exclude:
        any:
          - resources:
              namespaces:
                - kube-system
                - kube-node-lease
                - kube-public
                - kyverno
                - regionlock
      validate:
        message: >-
          BLOCKED: NetworkPolicy egress rule with no peer selector permits egress to any destination [GDPR Art. 46]
        deny:
          conditions:
            all:
              - key: "{{ length(request.object.spec.egress[] || '') }}"
                operator: GreaterThan
                value: "{{ length(request.object.spec.egress[?to] || '') }}"
