apiVersion: kyverno.io/v1
kind: ClusterPolicy
metadata:
  name: regionlock-encryption-at-rest
  labels:
    app.kubernetes.io/name: regionlock
    app.kubernetes.io/managed-by: regionlock
    app.kubernetes.io/instance: regionlock
    app.kubernetes.io/version: "1.0.0"
    regionlock.io/ruleset: «.RulesetID»
  annotations:
    regionlock.io/rule-id: encryption-at-rest
    policies.kyverno.io/title: Encryption At Rest
    policies.kyverno.io/severity: medium
    policies.kyverno.io/category: EU Data Residency
    policies.kyverno.io/subject: PersistentVolumeClaim
    regionlock.io/articles: "GDPR Art. 32"
    policies.kyverno.io/description: >-
      PersistentVolumeClaims must declare encryption at rest via the configured
      label, a baseline technical measure under the security-of-processing duty.
spec:
  validationFailureAction: Enforce
  background: true
  rules:
    - name: pvc-requires-encryption-label
      match:
        any:
          - resources:
              kinds:
                - PersistentVolumeClaim
      
      exclude:
        any:
          - resources:
              namespaces:
                - kube-system
                - kube-node-lease
                - kube-public
                - kyverno
                - regionlock
      validate:
        message: >-
          BLOCKED: PersistentVolumeClaim must declare encryption at rest. Label regionlock.io/encrypted=true or use an approved StorageClass [GDPR Art. 32]
        deny:
          conditions:
            all:
              - key: "{{ request.object.metadata.labels.\"regionlock.io/encrypted\" || '' }}"
                operator: NotEquals
                value: "true"
              - key: "{{ request.object.spec.storageClassName || '' }}"
                operator: AnyNotIn
                value: []
