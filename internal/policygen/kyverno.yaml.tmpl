    policies.kyverno.io/title: EU Region Placement
    policies.kyverno.io/severity: high
    policies.kyverno.io/category: EU Data Residency
    policies.kyverno.io/subject: Pod
    regionlock.io/articles: "GDPR Art. 44; GDPR Art. 45; EU Data Act Art. 32"
    policies.kyverno.io/description: >-
      Workloads must be pinned to an allow-listed EU cloud region via the
      topology.kubernetes.io/region label. Unconstrained or non-EU placement can
      schedule pods (and the personal data they process) outside the EEA.
spec:
  validationFailureAction: Enforce
  background: true
  rules:
    - name: region-nodeselector-must-be-eu
