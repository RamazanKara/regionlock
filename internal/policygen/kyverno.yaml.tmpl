# Source: regionlock/templates/policy-cmk.yaml
apiVersion: kyverno.io/v1
kind: ClusterPolicy
metadata:
  name: regionlock-customer-managed-key
  labels:
    app.kubernetes.io/name: regionlock
    app.kubernetes.io/managed-by: regionlock
    app.kubernetes.io/instance: regionlock
    app.kubernetes.io/version: "1.0.0"
    regionlock.io/ruleset: «.RulesetID»
  annotations:
    regionlock.io/rule-id: customer-managed-key
    policies.kyverno.io/title: Customer-Managed Key Storage
    policies.kyverno.io/severity: medium
    policies.kyverno.io/category: EU Data Residency
    policies.kyverno.io/subject: PersistentVolumeClaim
    regionlock.io/articles: "GDPR Art. 32"
    policies.kyverno.io/description: >-
      PersistentVolumeClaims must reference a customer-managed key so the data
      controller (not only the cloud provider) controls the encryption keys.
spec:
  validationFailureAction: Enforce
  background: true
  rules:
    - name: pvc-requires-cmk
      match:
        any:
          - resources:
              kinds:
                - PersistentVolumeClaim
      
      exclude:
        any:
          - resources:
              namespaces:
                - kube-system
                - kube-node-lease
                - kube-public
                - kyverno
                - regionlock
      validate:
        message: >-
          BLOCKED: PersistentVolumeClaim must reference a customer-managed key. Annotate regionlock.io/cmk-key-id or use an approved StorageClass [GDPR Art. 32]
        deny:
          conditions:
            all:
              - key: "{{ request.object.metadata.annotations.\"regionlock.io/cmk-key-id\" || '' }}"
                operator: Equals
                value: ""
              - key: "{{ request.object.spec.storageClassName || '' }}"
                operator: AnyNotIn
                value: []
