            operator: NotEquals
            value: ""
      validate:
        message: >-
          BLOCKED: non-EU region on nodeSelector (topology.kubernetes.io/region / failure-domain.beta.kubernetes.io/region) violates EU data-residency policy [GDPR Art. 44]
        deny:
          conditions:
            all:
              - key: "{{ [request.object.spec.nodeSelector.\"topology.kubernetes.io/region\", request.object.spec.nodeSelector.\"failure-domain.beta.kubernetes.io/region\"][?@] }}"
                operator: AnyNotIn
