<!doctype html>
<html lang="en">
<head>
<meta charset="utf-8">
<meta name="viewport" content="width=device-width, initial-scale=1">
<title>Regionlock Evidence — {{.Ruleset.Title}}</title>
<style>
  :root{
    --bg:#0b1020; --card:#141b31; --ink:#e8ecf6; --muted:#9aa6c4;
    --line:#243154; --pass:#1fbf75; --fail:#ff5d6c; --skip:#8b95b3; --accent:#4c8bf5;
  }
  *{box-sizing:border-box}
  body{margin:0;background:var(--bg);color:var(--ink);
    font:15px/1.5 -apple-system,BlinkMacSystemFont,"Segoe UI",Roboto,Helvetica,Arial,sans-serif}
  .wrap{max-width:900px;margin:0 auto;padding:32px 20px 56px}
  header{display:flex;align-items:center;gap:12px;margin-bottom:8px}
  .logo{font-weight:800;letter-spacing:-.02em;font-size:20px}
  .logo .lock{color:var(--accent)}
  .sub{color:var(--muted);font-size:13px;margin-bottom:24px}
  .banner{border-radius:14px;padding:22px 24px;display:flex;align-items:center;
    justify-content:space-between;gap:20px;margin-bottom:24px;border:1px solid var(--line)}
  .banner.ok{background:linear-gradient(90deg,rgba(31,191,117,.16),rgba(31,191,117,.04))}
  .banner.bad{background:linear-gradient(90deg,rgba(255,93,108,.18),rgba(255,93,108,.05))}
  .verdict{font-size:26px;font-weight:800}
  .verdict.ok{color:var(--pass)} .verdict.bad{color:var(--fail)}
  .score{text-align:right}
  .score b{font-size:34px;font-weight:800}
  .score span{display:block;color:var(--muted);font-size:12px}
  .grid{display:grid;grid-template-columns:repeat(4,1fr);gap:12px;margin-bottom:24px}
  .stat{background:var(--card);border:1px solid var(--line);border-radius:12px;padding:14px}
  .stat b{font-size:22px} .stat span{display:block;color:var(--muted);font-size:12px}
  h2{font-size:14px;text-transform:uppercase;letter-spacing:.08em;color:var(--muted);
    margin:28px 0 10px}
  table{width:100%;border-collapse:collapse;background:var(--card);
    border:1px solid var(--line);border-radius:12px;overflow:hidden}
  th,td{padding:11px 14px;text-align:left;border-bottom:1px solid var(--line);font-size:14px;vertical-align:top}
  th{color:var(--muted);font-weight:600;font-size:12px;text-transform:uppercase;letter-spacing:.04em}
  tr:last-child td{border-bottom:none}
  td.num{text-align:right;font-variant-numeric:tabular-nums}
  .pill{display:inline-block;padding:2px 9px;border-radius:999px;font-size:12px;font-weight:700}
  .pill.pass{background:rgba(31,191,117,.15);color:var(--pass)}
  .pill.fail{background:rgba(255,93,108,.15);color:var(--fail)}
  .sev{font-size:12px;color:var(--muted)}
  .art{color:var(--accent);font-size:12.5px}
  .mono{font-family:ui-monospace,SFMono-Regular,Menlo,Consolas,monospace;font-size:12px}
  code{font-family:ui-monospace,SFMono-Regular,Menlo,Consolas,monospace;font-size:12.5px;
    background:rgba(255,255,255,.05);padding:1px 5px;border-radius:5px}
  footer{margin-top:28px;color:var(--muted);font-size:12px;border-top:1px solid var(--line);padding-top:16px}
  .disc{font-style:italic;margin-top:8px}
</style>
</head>
<body>
<div class="wrap">
  <header>
    <div class="logo">region<span class="lock">lock</span></div>
    <div class="sub">Evidence Report</div>
  </header>
  <div class="sub">{{.Ruleset.Title}} · ruleset <code>{{.Ruleset.ID}}@{{.Ruleset.Version}}</code>
    · source <code>{{.Source}}</code> · generated {{.GeneratedAt}}</div>

  <div class="banner {{if .Summary.Compliant}}ok{{else}}bad{{end}}">
    <div class="verdict {{if .Summary.Compliant}}ok{{else}}bad{{end}}">
      {{if .Summary.Compliant}}✅ COMPLIANT{{else}}❌ NON-COMPLIANT{{end}}
    </div>
    <div class="score"><b>{{pct .Summary.Score}}</b><span>compliance score</span></div>
  </div>

  <div class="grid">
    <div class="stat"><b>{{.Summary.Resources}}</b><span>resources</span></div>
    <div class="stat"><b style="color:var(--pass)">{{.Summary.Pass}}</b><span>passing checks</span></div>
    <div class="stat"><b style="color:var(--fail)">{{.Summary.Fail}}</b><span>failing checks</span></div>
    <div class="stat"><b style="color:var(--skip)">{{.Summary.Skip}}</b><span>skipped</span></div>
  </div>

  <h2>Control summary</h2>
  <table>
    <tr><th>Control</th><th>Severity</th><th class="num">Pass</th><th class="num">Fail</th>
      <th class="num">Skip</th><th>Evidences (articles)</th></tr>
    {{range .RuleScores}}
    <tr>
      <td>{{.RuleName}}<div class="mono">{{.RuleID}}</div></td>
      <td class="sev">{{.Severity}}</td>
      <td class="num">{{.Pass}}</td>
      <td class="num">{{.Fail}}</td>
      <td class="num">{{.Skip}}</td>
      <td class="art">{{articles .Articles}}</td>
    </tr>
    {{end}}
  </table>

  {{if gt .Summary.Fail 0}}
  <h2>Failures</h2>
  <table>
    <tr><th>Control</th><th>Resource</th><th>Namespace</th><th>Detail</th><th>Articles</th></tr>
    {{range .Findings}}{{if eq (printf "%s" .Status) "fail"}}
    <tr>
      <td class="mono">{{.RuleID}}</td>
      <td class="mono">{{.Kind}}/{{.Name}}</td>
      <td>{{.Namespace}}</td>
      <td>{{.Message}}</td>
      <td class="art">{{articles .Articles}}</td>
    </tr>
    {{end}}{{end}}
  </table>
  {{end}}

  <h2>Namespaces</h2>
  <table>
    <tr><th>Namespace</th><th class="num">Pass</th><th class="num">Fail</th>
      <th class="num">Skip</th><th class="num">Score</th></tr>
    {{range .Namespaces}}
    <tr><td>{{.Namespace}}</td><td class="num">{{.Pass}}</td><td class="num">{{.Fail}}</td>
      <td class="num">{{.Skip}}</td><td class="num">{{pct .Score}}</td></tr>
    {{end}}
  </table>

  <footer>
    <div><b>Integrity</b> · {{.Integrity.Algorithm}}: <span class="mono">{{.Integrity.Digest}}</span></div>
    {{if .Integrity.Signature}}
    <div><b>Signature</b> · {{.Integrity.Signature.Algorithm}}:
      <span class="mono">{{.Integrity.Signature.Value}}</span></div>
    <div><b>Public key</b> · <span class="mono">{{.Integrity.Signature.PublicKey}}</span></div>
    {{end}}
    <div class="disc">{{disclaimer}}</div>
    <div class="disc">Generated by Regionlock {{.Version}}.</div>
  </footer>
</div>
</body>
</html>
